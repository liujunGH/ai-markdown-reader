{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist-electron",
    "rootDir": ".",
    "declaration": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "__tests__", "../dist", "../dist-electron", "../src"]
}
