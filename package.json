{
  "name": "markdown-reader",
  "private": true,
  "version": "1.4.0",
  "description": "A Markdown Reader",
  "author": "liujun",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && vite build && electron .",
    "electron:build": "npm run electron:compile && npm run build && electron-builder --win",
    "electron:build:mac": "npm run electron:compile && npm run build && electron-builder --mac",
    "electron:build:linux": "npm run electron:compile && npm run build && electron-builder --linux",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "dompurify": "^3.4.0",
    "electron-updater": "^6.8.3",
    "immer": "^11.1.4",
    "katex": "^0.16.45",
    "markdown-it": "^14.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-katex": "^2.0.3",
    "mermaid": "^10.6.0",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.0.0",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.1.5",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^4.1.5",
    "ws": "^8.20.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
